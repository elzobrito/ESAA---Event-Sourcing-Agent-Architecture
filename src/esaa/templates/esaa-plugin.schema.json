{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://esaa.local/schemas/esaa-plugin.schema.json",
  "title": "ESAA Plugin Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "name",
    "version",
    "kind",
    "esaa_core",
    "entrypoints",
    "task_id_namespace",
    "capabilities"
  ],
  "properties": {
    "schema_version": {
      "const": "esaa-plugin/v1"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(?:[-+][0-9A-Za-z.-]+)?$"
    },
    "kind": {
      "const": "roadmap_plugin"
    },
    "esaa_core": {
      "type": "object",
      "additionalProperties": false,
      "required": ["min_version", "max_version"],
      "properties": {
        "min_version": { "type": "string", "minLength": 1 },
        "max_version": { "type": "string", "minLength": 1 }
      }
    },
    "entrypoints": {
      "type": "object",
      "additionalProperties": false,
      "required": ["roadmap", "input_example", "input_schema"],
      "properties": {
        "roadmap": { "type": "string", "minLength": 1 },
        "input_example": { "type": "string", "minLength": 1 },
        "input_schema": { "type": "string", "minLength": 1 }
      }
    },
    "task_id_namespace": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "capabilities": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "external_targets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "root_input", "allowed_write", "runtime_contract"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:[-_][a-z0-9]+)*$"
          },
          "root_input": {
            "type": "string",
            "minLength": 1
          },
          "allowed_write": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "runtime_contract": {
            "type": "string",
            "minLength": 1
          },
          "runtime_uri_prefixes": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^runtime://[A-Za-z0-9_.-]+\\.$"
            }
          },
          "runtime_uri_prefix": {
            "type": "string",
            "pattern": "^runtime://[A-Za-z0-9_.-]+\\.$"
          }
        }
      }
    }
  }
}
